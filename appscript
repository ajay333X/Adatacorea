function getUserDashboardData(e) {
  const userId = e.parameter.userId;

  const sheet = SpreadsheetApp
    .openById(SPREADSHEET_ID)
    .getSheetByName(SUBMISSIONS_SHEET_NAME);

  if (!sheet) {
    return { ok: false, error: "Submissions sheet not found" };
  }

  const rows = sheet.getDataRange().getValues();
  rows.shift(); // remove header

  let tasks = 0;
  let totalEarnings = 0;

  rows.forEach(row => {
    if (String(row[1]) === String(userId)) {
      tasks++;
      totalEarnings += Number(row[4] || 0); // earnings column
    }
  });

  totalEarnings = Number(totalEarnings.toFixed(2));

  return {
    ok: true,
    stats: {
      tasksCompleted: tasks,
      totalEarnings: totalEarnings,
      pendingEarnings: totalEarnings // same for now
    }
  };
}
