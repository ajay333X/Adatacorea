function doGet(e) {
  try {
    const action = String(e.parameter.action || "").trim();
    const idToken = String(e.parameter.idToken || "").trim();

    if (!action) return json_({ ok: false, error: "Missing action" });
    if (!idToken) return json_({ ok: false, error: "Missing idToken" });

    const authInfo = verifyFirebaseIdToken_(idToken);
    const uid = authInfo.uid;

    if (action === "getUserDashboardData") {
      return json_(getUserDashboardDataByUid_(uid));
    }

    if (action === "getUserEarnings") {
      const limitN = Number(e.parameter.limit || 50);
      return json_(getUserEarningsByUid_(uid, limitN));
    }

    return json_({ ok: false, error: "Invalid action" });

  } catch (err) {
    return json_({ ok: false, error: String(err && err.stack ? err.stack : err) });
  }
}


