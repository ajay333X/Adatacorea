// ============================
// HELPERS
// ============================
function verifyFirebaseIdToken_(idToken) {
  const url = `https://identitytoolkit.googleapis.com/v1/accounts:lookup?key=${FIREBASE_WEB_API_KEY}`;
  const res = UrlFetchApp.fetch(url, {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify({ idToken }),
    muteHttpExceptions: true
  });

  const data = JSON.parse(res.getContentText() || "{}");
  if (!data.users || !data.users[0]) throw new Error("Invalid token");

  return {
    uid: data.users[0].localId,
    email: data.users[0].email
  };
}

function idxMap_(headerRow) {
  const map = {};
  headerRow.forEach((h, i) => {
    const key = String(h).trim().toLowerCase();
    map[key] = i;
  });

  return {
    taskId: map.taskid,
    audioUrl: map.audiourl,
    instruction: map.instruction,
    taskType: map.tasktype,
    status: map.status,
    assignedTo: map.assignedto,
    assignedAt: map.assignedat,
    completedAt: map.completedat,
    pay: map.pay
  };
}

function headerIndex_(headerRow) {
  const out = {};
  headerRow.forEach((h, i) => {
    out[String(h).trim().toLowerCase()] = i;
  });

  // convenient aliases (may be undefined if header missing)
  return {
    timestamp: out.timestamp,
    userid: out.userid,
    taskid: out.taskid,
    durationsec: out.durationsec,
    earnings: out.earnings,
    drivefileurl: out.drivefileurl,
    drivefileid: out.drivefileid,
    status: out.status,

    paidat: out.paidat,
    weekkey: out.weekkey,
    amountpaid: out.amountpaid,
    paidby: out.paidby
  };
}

function requireHeaders_(idx, keys) {
  for (const k of keys) {
    if (idx[k] == null) throw new Error(`Header missing in tasks sheet: ${k}`);
  }
}

function norm_(v) {
  return String(v == null ? "" : v).trim().toLowerCase();
}

function json_(obj) {
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}

function toNumberSafe_(v) {
  if (typeof v === "number") return v;
  if (v == null) return 0;

  const s = String(v).trim();
  // keep digits, dot, minus; remove currency etc
  const n = parseFloat(s.replace(/[^\d.\-]/g, ""));
  return isNaN(n) ? 0 : n;
}

function getUserDashboardDataByUid_(uid) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName(SUBMISSIONS_SHEET_NAME);
  if (!sheet) return { ok: true, stats: { tasksCompleted: 0, totalEarnings: 0, pendingEarnings: 0 } };

  const rows = sheet.getDataRange().getValues();
  if (rows.length < 2) return { ok: true, stats: { tasksCompleted: 0, totalEarnings: 0, pendingEarnings: 0 } };

  const h = headerIndex_(rows[0]);
  const colUser = h.userid;
  const colEarn = h.earnings;
  const colStatus = h.status;

  if (colUser == null || colEarn == null || colStatus == null) {
    return { ok: false, error: "Submissions sheet missing header: userId / earnings / status" };
  }

  let tasks = 0;
  let total = 0;
  let paid = 0;

  for (let i = 1; i < rows.length; i++) {
    const r = rows[i];
    if (String(r[colUser] || "").trim() !== String(uid)) continue;

    const status = String(r[colStatus] || "").trim().toLowerCase();
    const earn = toNumberSafe_(r[colEarn]);

    if (status === "submitted" || status === "paid") tasks++;
    total += earn;
    if (status === "paid") paid += earn;
  }

  total = Number(total.toFixed(2));
  paid = Number(paid.toFixed(2));
  const pending = Number((total - paid).toFixed(2));

  return { ok: true, stats: { tasksCompleted: tasks, totalEarnings: total, pendingEarnings: pending } };
}




