function doGet(e) {
  try {
    const action = e.parameter.action;
    let result;

    if (action === "getUserDashboardData") {
      result = getUserDashboardData(e);
    } else {
      result = { ok: false, error: "Invalid action" };
    }

    return ContentService
      .createTextOutput(JSON.stringify(result))
      .setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    return ContentService
      .createTextOutput(JSON.stringify({
        ok: false,
        error: String(err)
      }))
      .setMimeType(ContentService.MimeType.JSON);
  }
}



function doPost(e) {
  try {
    let data = {};
    let params = e && e.parameter ? e.parameter : {};

    // Try JSON first
    if (e && e.postData && e.postData.contents) {
      try {
        data = JSON.parse(e.postData.contents);
      } catch (err) {
        data = {}; // ignore, not JSON
      }
    }

    // ✅ ALWAYS MERGE (THIS IS THE KEY FIX)
    const body = { ...params, ...data };

    const action = String(body.action || "").trim();
    const idToken = String(body.idToken || "").trim();

    if (!action) return json_({ ok: false, error: "Missing action" });
    if (!idToken) return json_({ ok: false, error: "Missing idToken" });

    const authInfo = verifyFirebaseIdToken_(idToken);
    const uid = authInfo.uid;

    if (action === "assignAudioTask") {
      return json_(assignAudioTask_(uid));
    }

    if (action === "submitAudioTask") {
      return json_(submitAudioTask_(uid, body)); // ✅ PASS MERGED BODY
    }

    if (action === "skipAudioTask") {
      return json_(skipAudioTask_(uid, body));
    }

    return json_({ ok: false, error: "Unknown action" });
  } catch (err) {
    return json_({
      ok: false,
      error: String(err && err.stack ? err.stack : err)
    });
  }
}

/**
 * ✅ Expected JSON body:
 * {
 *   action: "submitAudioTask",
 *   idToken: "...",
 *   taskId: "AUDIO_001",
 *   durationSec: 83,
 *   mimeType: "audio/webm",
 *   audioBase64: "...."
 * }
 */
function submitAudioTask_(uid, body) {
// 🔍 DEBUG: log exactly what the backend receives
  Logger.log("BODY RECEIVED: " + JSON.stringify(body));

  const taskId = String(body.taskId || body.taskid || "").trim();
  const durationSec = Number(body.durationSec || body.durationsec || 0);
  const earnings = Number(body.earnings || 0);
  const mimeType = String(body.mimeType || body.mimetype || "audio/webm");
  const audioBase64 = String(body.audioBase64 || body.audiobase64 || "");

  if (!taskId) return { ok: false, error: "taskId missing" };
  if (!audioBase64) return { ok: false, error: "audioBase64 missing" };

  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);

  // ----- TASKS SHEET -----
  const tasksSheet = ss.getSheetByName(TASKS_SHEET_NAME);
  if (!tasksSheet) return { ok: false, error: `Sheet not found: ${TASKS_SHEET_NAME}` };

  const values = tasksSheet.getDataRange().getValues();
  if (values.length < 2) return { ok: false, error: "No tasks in sheet" };

  const idx = idxMap_(values[0]);

  // Validate required columns
  if (idx.taskId == null || idx.status == null || idx.assignedTo == null) {
    return {
      ok: false,
      error: "Header mismatch. Required headers: taskId, status, assignedTo (check spelling/case)."
    };
  }

  // Find task row
  let rowIndex = -1;
  for (let r = 1; r < values.length; r++) {
    if (String(values[r][idx.taskId]).trim() === taskId) {
      rowIndex = r;
      break;
    }
  }
  if (rowIndex === -1) return { ok: false, error: "TaskId not found" };

  const row = values[rowIndex];
  const status = String(row[idx.status]).trim();
  const assignedTo = String(row[idx.assignedTo]).trim();

  // Ownership check
  if (status !== "assigned") return { ok: false, error: `Task status is "${status}", not "assigned"` };
  if (assignedTo !== String(uid)) return { ok: false, error: "Task not assigned to this user" };

  // ----- SAVE AUDIO TO DRIVE -----
  const bytes = Utilities.base64Decode(audioBase64);
  const ext = mimeType.includes("webm") ? "webm" : "bin";
  const fileName = `${uid}_${taskId}_${Date.now()}.${ext}`;

  const blob = Utilities.newBlob(bytes, mimeType, fileName);
  const folder = DriveApp.getFolderById(DRIVE_FOLDER_ID);
  const file = folder.createFile(blob).setName(fileName);

  const driveUrl = file.getUrl();
  const fileId = file.getId();

  // ----- MARK COMPLETED IN TASKS -----
  tasksSheet.getRange(rowIndex + 1, idx.status + 1).setValue("completed");
  if (idx.completedAt != null) {
    tasksSheet.getRange(rowIndex + 1, idx.completedAt + 1).setValue(new Date());
  }

  // ----- SUBMISSIONS SHEET -----
  let sub = ss.getSheetByName(SUBMISSIONS_SHEET_NAME);
  if (!sub) {
    sub = ss.insertSheet(SUBMISSIONS_SHEET_NAME);
    sub.appendRow(["timestamp", "userId", "taskId", "durationSec", "earnings", "driveFileUrl", "driveFileId", "status"]);
  }

  sub.appendRow([
    new Date(),
    uid,
    taskId,
    durationSec,
    earnings,
    driveUrl,
    fileId,
    "submitted"
  ]);


return {
  ok: true,
  message: "Submitted successfully",
  result: {
    taskId,
    durationSec,
    driveUrl,
    fileId,
    earnings
  }
};

  Logger.log("Using spreadsheet: " + SPREADSHEET_ID);
Logger.log("Looking for taskId: " + taskId);

}

