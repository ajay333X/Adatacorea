// Assign: returns existing assigned task OR assigns first available audio task
function assignAudioTask_(uid) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sh = ss.getSheetByName(TASKS_SHEET_NAME);
  if (!sh) return { ok: false, error: `Sheet not found: ${TASKS_SHEET_NAME}` };

  const values = sh.getDataRange().getValues();
  if (values.length < 2) return { ok: false, error: "No tasks in sheet" };

  const idx = idxMap_(values[0]);

  requireHeaders_(idx, ["taskId", "audioUrl", "instruction", "taskType", "status", "assignedTo"]);

  // 1) return already assigned
  for (let r = 1; r < values.length; r++) {
    const row = values[r];
    const status = norm_(row[idx.status]);
    const assignedTo = String(row[idx.assignedTo] || "").trim();
    if (status === "assigned" && assignedTo === String(uid)) {
      return {
        ok: true,
        task: {
          taskId: String(row[idx.taskId] || "").trim(),
          audioUrl: String(row[idx.audioUrl] || "").trim(),
          instruction: String(row[idx.instruction] || "").trim(),
          taskType: String(row[idx.taskType] || "audio").trim(),
          pay: idx.pay != null ? Number(row[idx.pay] || 0) : 0
        }
      };
    }
  }

  // 2) assign first available audio task
  for (let r = 1; r < values.length; r++) {
    const row = values[r];
    const status = norm_(row[idx.status]);
    const taskType = norm_(row[idx.taskType] || "audio");

    if (taskType === "audio" && (status === "" || status === "available")) {
      const now = new Date();
      sh.getRange(r + 1, idx.status + 1).setValue("assigned");
      sh.getRange(r + 1, idx.assignedTo + 1).setValue(uid);
      if (idx.assignedAt != null) sh.getRange(r + 1, idx.assignedAt + 1).setValue(now);

      return {
        ok: true,
        task: {
          taskId: String(row[idx.taskId] || "").trim(),
          audioUrl: String(row[idx.audioUrl] || "").trim(),
          instruction: String(row[idx.instruction] || "").trim(),
          taskType: String(row[idx.taskType] || "audio").trim(),
          pay: idx.pay != null ? Number(row[idx.pay] || 0) : 0
        }
      };
    }
  }

  return { ok: false, error: "No available audio tasks" };
}

// Submit: verify ownership + save audio + compute earnings from tasks sheet "pay"
function submitAudioTask_(uid, body) {
  const taskId = String(body.taskId || body.taskid || "").trim();
  const durationSec = Number(body.durationSec || body.durationsec || 0);
  const mimeType = String(body.mimeType || body.mimetype || "audio/webm");
  const audioBase64 = String(body.audioBase64 || body.audiobase64 || "");

  if (!taskId) return { ok: false, error: "taskId missing" };
  if (!audioBase64) return { ok: false, error: "audioBase64 missing" };

  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const tasksSheet = ss.getSheetByName(TASKS_SHEET_NAME);
  if (!tasksSheet) return { ok: false, error: `Sheet not found: ${TASKS_SHEET_NAME}` };

  const values = tasksSheet.getDataRange().getValues();
  if (values.length < 2) return { ok: false, error: "No tasks in sheet" };

  const idx = idxMap_(values[0]);
  requireHeaders_(idx, ["taskId", "status", "assignedTo"]);

  // find task row
  let rowIndex = -1;
  for (let r = 1; r < values.length; r++) {
    if (String(values[r][idx.taskId]).trim() === taskId) {
      rowIndex = r;
      break;
    }
  }
  if (rowIndex === -1) return { ok: false, error: "TaskId not found" };

  const row = values[rowIndex];
  const status = String(row[idx.status] || "").trim();
  const assignedTo = String(row[idx.assignedTo] || "").trim();

  if (status !== "assigned") return { ok: false, error: `Task status is "${status}", not "assigned"` };
  if (assignedTo !== String(uid)) return { ok: false, error: "Task not assigned to this user" };

  // ✅ Earnings computed server-side from duration
  const HOURLY_RATE = 7.5;
  const earnings = Number(((durationSec / 3600) * HOURLY_RATE).toFixed(2));

  // save audio to Drive
  const bytes = Utilities.base64Decode(audioBase64);
  const ext = mimeType.includes("webm") ? "webm" : "bin";
  const fileName = `${uid}_${taskId}_${Date.now()}.${ext}`;

  const blob = Utilities.newBlob(bytes, mimeType, fileName);
  const folder = DriveApp.getFolderById(DRIVE_FOLDER_ID);
  const file = folder.createFile(blob).setName(fileName);

  const driveUrl = file.getUrl();
  const fileId = file.getId();

  // mark completed in tasks
  tasksSheet.getRange(rowIndex + 1, idx.status + 1).setValue("completed");
  if (idx.completedAt != null) tasksSheet.getRange(rowIndex + 1, idx.completedAt + 1).setValue(new Date());

  // append to submissions sheet (your screenshot matches this schema)
  let sub = ss.getSheetByName(SUBMISSIONS_SHEET_NAME);
  if (!sub) {
    sub = ss.insertSheet(SUBMISSIONS_SHEET_NAME);
    sub.appendRow(["timestamp", "userId", "taskId", "durationSec", "earnings", "driveFileUrl", "quality", "status"]);
  }

  sub.appendRow([
    new Date(),
    uid,
    taskId,
    durationSec,
    earnings,
    driveUrl,
    "",          // quality placeholder
    "submitted"
  ]);

  return {
    ok: true,
    message: "Submitted successfully",
    result: { taskId, durationSec,earnings, driveUrl, fileId }
  };
}


// Skip: mark skipped (optional reason)
function skipAudioTask_(uid, body) {
  const taskId = String(body.taskId || "").trim();
  const reason = String(body.reason || "").trim();

  if (!taskId) return { ok: false, error: "taskId missing" };

  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const tasksSheet = ss.getSheetByName(TASKS_SHEET_NAME);
  if (!tasksSheet) return { ok: false, error: `Sheet not found: ${TASKS_SHEET_NAME}` };

  const values = tasksSheet.getDataRange().getValues();
  if (values.length < 2) return { ok: false, error: "No tasks in sheet" };

  const idx = idxMap_(values[0]);
  requireHeaders_(idx, ["taskId", "status", "assignedTo"]);

  let rowIndex = -1;
  for (let r = 1; r < values.length; r++) {
    if (String(values[r][idx.taskId]).trim() === taskId) {
      rowIndex = r;
      break;
    }
  }
  if (rowIndex === -1) return { ok: false, error: "TaskId not found" };

  const row = values[rowIndex];
  const status = String(row[idx.status] || "").trim();
  const assignedTo = String(row[idx.assignedTo] || "").trim();

  if (status !== "assigned") return { ok: false, error: `Task status is "${status}", not "assigned"` };
  if (assignedTo !== String(uid)) return { ok: false, error: "Task not assigned to this user" };

  tasksSheet.getRange(rowIndex + 1, idx.status + 1).setValue("skipped");
  if (idx.completedAt != null) tasksSheet.getRange(rowIndex + 1, idx.completedAt + 1).setValue(new Date());

  // optionally log
  let sub = ss.getSheetByName(SUBMISSIONS_SHEET_NAME);
  if (!sub) {
    sub = ss.insertSheet(SUBMISSIONS_SHEET_NAME);
    sub.appendRow(["timestamp", "userId", "taskId", "durationSec", "earnings", "driveFileUrl", "driveFileId", "status"]);
  }
  sub.appendRow([new Date(), uid, taskId, 0, 0, "", "", "skipped"]);

  return { ok: true, message: "Task skipped", taskId, reason };
}

// Dashboard stats (SECURE: uid from token, not from client)
function getDashboardStats_(uid) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = ss.getSheetByName(SUBMISSIONS_SHEET_NAME);
  if (!sheet) {
    return { ok: true, stats: { tasksCompleted: 0, totalEarnings: 0, pendingEarnings: 0 } };
  }

  const rows = sheet.getDataRange().getValues();
  if (rows.length < 2) {
    return { ok: true, stats: { tasksCompleted: 0, totalEarnings: 0, pendingEarnings: 0 } };
  }

  const header = headerIndex_(rows[0]);
  const colUser = header.userid;
  const colEarn = header.earnings;
  const colStatus = header.status;

  let tasks = 0;
  let total = 0;
  let paid = 0;

  for (let i = 1; i < rows.length; i++) {
    const r = rows[i];
    if (String(r[colUser] || "").trim() !== String(uid)) continue;

    const earn = Number(r[colEarn] || 0);
    const status = norm_(r[colStatus] || "");

    // Count only submitted/paid as completed tasks
    if (status === "submitted" || status === "paid") tasks++;
    total += earn;

    if (status === "paid") paid += earn;
  }

  total = Number(total.toFixed(2));
  paid = Number(paid.toFixed(2));
  const pending = Number((total - paid).toFixed(2));

  return {
    ok: true,
    stats: { tasksCompleted: tasks, totalEarnings: total, pendingEarnings: pending }
  };
}

